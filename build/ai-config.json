{
  "_comment": "开发者配置文件：管理所有 AI provider 的接口地址、模型名和 env key 变量名。修改 llm.active / image.active 可在不同 provider 间切换（需重新 npm run dev 或重新构建）。API key 请写到 .env.local（参考 .env.local.example），不要写在本文件中。",

  "llm": {
    "_comment": "active 填写下方 providers 中某一个 id，切换后需重启 dev server 或重新构建。",
    "active": "cuhk",

    "providers": {
      "cuhk": {
        "label": "CUHK (香港中文大学)",
        "defaultModel": "qwen3-5-397b-a17b",
        "defaultBaseUrl": "https://ai.cuhk.edu.cn/open/v1",
        "builtinKeySupported": true,
        "builtinKeyEnvNames": ["AI_WRITER_DEFAULT_CUHK_API_KEY", "CUHK_API_KEY"]
      },
      "qwen": {
        "label": "Qwen (阿里云)",
        "defaultModel": "qwen3.6-plus",
        "defaultBaseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "builtinKeySupported": true,
        "builtinKeyEnvNames": ["AI_WRITER_DEFAULT_QWEN_API_KEY", "QWEN_API_KEY"]
      },
      "deepseek": {
        "label": "DeepSeek",
        "defaultModel": "deepseek-chat",
        "defaultBaseUrl": "https://api.deepseek.com/v1",
        "builtinKeySupported": true,
        "builtinKeyEnvNames": ["AI_WRITER_DEFAULT_DEEPSEEK_API_KEY", "DEEPSEEK_API_KEY"]
      },
      "openai": {
        "label": "OpenAI",
        "defaultModel": "gpt-4.1-mini",
        "defaultBaseUrl": "https://api.openai.com/v1",
        "builtinKeySupported": false,
        "builtinKeyEnvNames": []
      },
      "anthropic": {
        "label": "Anthropic",
        "defaultModel": "claude-3-5-sonnet-latest",
        "defaultBaseUrl": "https://api.anthropic.com/v1/messages",
        "builtinKeySupported": false,
        "builtinKeyEnvNames": []
      },
      "custom": {
        "label": "自定义兼容接口",
        "defaultModel": "",
        "defaultBaseUrl": "",
        "builtinKeySupported": false,
        "builtinKeyEnvNames": []
      }
    }
  },

  "image": {
    "_comment": "active 填写下方 providers 中某一个 id。",
    "active": "nanobanana",

    "providers": {
      "nanobanana": {
        "label": "Nanobanana",
        "defaultModel": "nano-banana-pro",
        "defaultEndpoint": "https://grsai.dakka.com.cn/v1/draw/nano-banana",
        "builtinKeySupported": true,
        "builtinKeyEnvNames": ["AI_WRITER_DEFAULT_NANOBANANA_API_KEY", "NANOBANANA_API_KEY"]
      },
      "openai-image": {
        "label": "OpenAI Image",
        "defaultModel": "gpt-image-1",
        "defaultEndpoint": "https://api.openai.com/v1/images/generations",
        "builtinKeySupported": false,
        "builtinKeyEnvNames": []
      },
      "custom": {
        "label": "自定义图片接口",
        "defaultModel": "",
        "defaultEndpoint": "",
        "builtinKeySupported": false,
        "builtinKeyEnvNames": []
      }
    }
  }
}
