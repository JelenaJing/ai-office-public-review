# AI Writer 3.0 — 环境变量配置示例
# 复制为 .env.local 并填入实际值（.env.local 已被 .gitignore 忽略）

# ─── LLM Keys ─────────────────────────────────────────────
QWEN_API_KEY=your-qwen-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# ─── Image Keys ────────────────────────────────────────────
NANOBANANA_API_KEY=your-nanobanana-api-key

# ─── Remote Skill Store（默认：服务器模式）────────────────────
# 商店 / 授权 / 下载 走服务器；本地 Engine 仍在本机
SKILL_STORE_BASE_URL=http://10.20.5.62:4030
SKILL_LIBRARY_BASE_URL=http://10.20.5.62:4010
SKILL_ENGINE_BASE_URL=http://localhost:4020

# ─── Local development override（取消注释可切回本地模式）────────
# SKILL_STORE_BASE_URL=http://localhost:4030
# SKILL_LIBRARY_BASE_URL=http://localhost:4010
# SKILL_ENGINE_BASE_URL=http://localhost:4020

# ─── Skill Platform Internal Token ────────────────────────
# SKILL_INTERNAL_API_TOKEN=change-this-token

# ─── Demo auth behavior ────────────────────────────────────
# 演示阶段默认在前端绕过首次登录强制改密；正式版本可设为 false 重新启用。
VITE_DISABLE_FORCE_PASSWORD_CHANGE=true

# ─── Demo: 日报权限开放 ────────────────────────────────────
# 开启后所有登录用户都能查看/生成所有 active 用户的日报（演示模式）。
# 正式环境设为 false 可恢复原有权限逻辑（仅 admin / 上下级 / canViewWorkReport=true）。
VITE_ALLOW_ALL_WORK_REPORTS=true
